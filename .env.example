# ========================================
# EGX Pro Terminal v26 - Environment File
# ========================================
# انسخ هذا الملف باسم .env وملأ القيم الخاصة بك

# ========== STREAMLIT CONFIGURATION ==========
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_SERVER_HEADLESS=false
STREAMLIT_SERVER_RUN_ON_SAVE=true

# ========== DATABASE CONFIGURATION ==========
# إذا كنت تستخدم قاعدة بيانات
DB_HOST=localhost
DB_PORT=5432
DB_NAME=egx_pro_terminal
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_TYPE=postgresql

# ========== API CONFIGURATION ==========
# مفاتيح API الخارجية
EGX_API_KEY=your_api_key_here
EGX_API_URL=https://api.egx.com.eg

# ========== TELEGRAM NOTIFICATIONS ==========
# إذا كنت تريد إرسال تنبيهات عبر Telegram
TELEGRAM_BOT_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id

# ========== EMAIL CONFIGURATION ==========
# إذا كنت تريد إرسال تنبيهات بريدية
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM_NAME=EGX Pro Terminal

# ========== LOGGING CONFIGURATION ==========
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ========== SECURITY ==========
# مفاتيح الأمان
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== CACHE CONFIGURATION ==========
CACHE_TYPE=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ========== DEVELOPMENT ==========
DEBUG=false
TESTING=false
ENVIRONMENT=production

# development (للاختبار)
# production (للإنتاج)
# staging (للتجريب)

# ========== CORS CONFIGURATION ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
CORS_ALLOW_CREDENTIALS=true

# ========== DATA PATHS ==========
DATA_DIR=./data
LOGS_DIR=./logs
TEMP_DIR=./temp
CACHE_DIR=./cache

# ========== API RATE LIMITING ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ========== FEATURES FLAGS ==========
# تفعيل/تعطيل الميزات
FEATURE_ALERTS_ENABLED=true
FEATURE_RISK_ANALYSIS_ENABLED=true
FEATURE_STOCK_SCREENER_ENABLED=true
FEATURE_STRATEGIES_ENABLED=true
FEATURE_PDF_REPORTS_ENABLED=true

# ========== ADMIN CONFIGURATION ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password_here
ADMIN_EMAIL=admin@egxpro.com

# ========== MONITORING ==========
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ========== ANALYTICS ==========
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=

# ========== EXTERNAL SERVICES ==========
# Google Drive API (للتقارير)
GOOGLE_DRIVE_API_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# AWS S3 (للنسخ الاحتياطية)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=egx-pro-terminal-backups

# ========== TIMEZONE & LOCALIZATION ==========
TIMEZONE=Africa/Cairo
LANGUAGE=ar
CURRENCY=EGP

# ========== PERFORMANCE ==========
MAX_WORKERS=4
REQUEST_TIMEOUT=30
CONNECTION_POOL_SIZE=10

# ========== STOCK MARKET DATA ==========
# مصادر البيانات
DATA_SOURCE=api  # api, csv, database
UPDATE_INTERVAL=300  # بالثواني
HISTORICAL_DATA_DAYS=365

# ========== NOTIFICATION SETTINGS ==========
NOTIFICATION_ENABLED=true
NOTIFICATION_CHECK_INTERVAL=60
NOTIFICATION_TIMEOUT=30

# ========== BACKUP CONFIGURATION ==========
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # كل 24 ساعة
BACKUP_RETENTION_DAYS=30

# ========== VERSION & BUILD ==========
APP_VERSION=26.0.0
APP_NAME=EGX Pro Terminal
BUILD_DATE=2026-05-16

# =========== NOTES ===========
# 1. احذر من مشاركة هذا الملف مع الآخرين
# 2. لا تضع الملف الفعلي في Git (استخدم .gitignore)
# 3. استخدم قيم آمنة وقوية للكلمات المرورية
# 4. حدّث القيم حسب بيئتك
# 5. تحقق من التوثيق قبل تغيير أي إعداد
