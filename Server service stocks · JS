/**
 * مقارنة عدة أسهم
 */
exports.compareStocks = async (stockIds) => {
  try {
    logger.info(`جاري مقارنة الأسهم: ${stockIds.join(', ')}`);

    const comparison = await Promise.all(
      stockIds.map(id => this.getStockById(id))
    );

    // ترتيب حسب الأداء
    const sorted = comparison.sort((a, b) => b.changePercent - a.changePercent);

    return sorted.map((stock, index) => ({
      ...stock,
      rank: index + 1,
      performance: 'قوي',
    }));
  } catch (error) {
    logger.error(`خطأ في المقارنة: ${error.message}`);
    throw error;
  }
};

