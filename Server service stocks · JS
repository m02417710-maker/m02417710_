/**
 * الحصول على قائمة الأسهم مع الفلترة
 */
exports.getStocks = async (options = {}) => {
  try {
    const {
      page = 1,
      limit = 20,
      sector,
      minPrice,
      maxPrice,
      sort = 'price',
    } = options;

    logger.info(`جاري جلب الأسهم - الفلاترة: ${JSON.stringify(options)}`);

    // فلترة الأسهم
    let filtered = mockStocks;

    if (sector) {
      filtered = filtered.filter(s => s.sector === sector);
    }

    if (minPrice) {
      filtered = filtered.filter(s => s.currentPrice >= minPrice);
    }

    if (maxPrice) {
      filtered = filtered.filter(s => s.currentPrice <= maxPrice);
    }

    // ترتيب الأسهم
    if (sort === 'price') {
      filtered.sort((a, b) => b.currentPrice - a.currentPrice);
    } else if (sort === 'change') {
      filtered.sort((a, b) => b.changePercent - a.changePercent);
    }

    // التقسيم إلى صفحات
    const start = (page - 1) * limit;
    const end = start + limit;
    const paginatedData = filtered.slice(start, end);

    return {
      data: paginatedData,
      total: filtered.length,
    };
  } catch (error) {
    logger.error(`خطأ في جلب الأسهم: ${error.message}`);
    throw error;
  }
};

/**
 * الحصول على تفاصيل سهم محدد
 */
exports.getStockById = async (stockId) => {
  try {
    logger.info(`جاري جلب تفاصيل السهم: ${stockId}`);

    // البحث عن السهم
    const stock = mockStocks.find(s => s.id === stockId);

    if (!stock) {
      throw new Error('السهم غير موجود');
    }

    // إضافة المؤشرات الفنية
    const indicators = await technicalService.calculateIndicators(stockId, 30);

    return {
      ...stock,
      indicators,
      lastUpdated: new Date(),
    };
  } catch (error) {
    logger.error(`خطأ في جلب السهم: ${error.message}`);
    throw error;
  }
};

/**
 * الحصول على البيانات التاريخية
 */
exports.getStockHistory = async (stockId, options = {}) => {
  try {
    const {
      startDate,
      endDate,
      interval = 'daily',
    } = options;

    logger.info(`جاري جلب السجل التاريخي للسهم: ${stockId}`);

    // إنشاء بيانات تاريخية وهمية
    const history = [];
    const days = 30;

    for (let i = days; i >= 0; i--) {
      const date = new Date();
      date.setDate(date.getDate() - i);

      history.push({
        date: date.toISOString().split('T')[0],
        open: 17.5 + Math.random() * 2,
        high: 18.5 + Math.random() * 1,
        low: 17 + Math.random() * 1,
        close: 17.5 + Math.random() * 2,
        volume: Math.floor(Math.random() * 5000000) + 1000000,
      });
    }

    return history;
  } catch (error) {
    logger.error(`خطأ في جلب السجل: ${error.message}`);
    throw error;
  }
};

/**
 * الحصول على التوصيات
 */
exports.getRecommendations = async (stockId) => {
  try {
    logger.info(`جاري حساب التوصيات للسهم: ${stockId}`);

    const stock = mockStocks.find(s => s.id === stockId);
    if (!stock) throw new Error('السهم غير موجود');

    // حساب درجة التوصية
    let score = 50;

    // معايير أساسية
    if (stock.pe < 15) score += 15;
    if (stock.dividendYield > 3) score += 15;
    if (stock.changePercent > 0) score += 10;

    // التوصية النهائية
    let recommendation = 'احتفاظ';
    if (score >= 75) recommendation = 'شراء قوي';
    else if (score >= 65) recommendation = 'شراء';
    else if (score >= 40) recommendation = 'احتفاظ';
    else recommendation = 'بيع';

    return {
      score,
      recommendation,
      reasons: [
        `مكرر الربحية: ${stock.pe}`,
        `عائد التوزيع: ${stock.dividendYield}%`,
        `التغير: ${stock.changePercent}%`,
      ],
    };
  } catch (error) {
    logger.error(`خطأ في حساب التوصيات: ${error.message}`);
    throw error;
  }
};

