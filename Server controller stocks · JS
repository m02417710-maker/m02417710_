/**
 * متحكم الأسهم
 * Stock Controller
 */

const logger = require('../utils/logger');
const stockService = require('../services/stockService');
const technicalService = require('../services/technicalIndicators');

// ============================================================
// GET - الحصول على البيانات
// ============================================================

/**
 * الحصول على قائمة الأسهم
 */
exports.getStocks = async (req, res, next) => {
  try {
    const {
      page = 1,
      limit = 20,
      sector,
      minPrice,
      maxPrice,
      sort = 'price',
    } = req.query;

    logger.info(`جاري جلب الأسهم - الصفحة ${page}, الحد ${limit}`);

    const stocks = await stockService.getStocks({
      page,
      limit,
      sector,
      minPrice,
      maxPrice,
      sort,
    });

    res.json({
      success: true,
      data: stocks.data,
      pagination: {
        page,
        limit,
        total: stocks.total,
        totalPages: Math.ceil(stocks.total / limit),
      },
    });
  } catch (error) {
    logger.error(`خطأ في جلب الأسهم: ${error.message}`);
    next(error);
  }
};

/**
 * الحصول على تفاصيل سهم محدد
 */
exports.getStockById = async (req, res, next) => {
  try {
    const { id } = req.params;

    logger.info(`جاري جلب تفاصيل السهم: ${id}`);

    const stock = await stockService.getStockById(id);

    if (!stock) {
      return res.status(404).json({
        success: false,
        message: 'السهم غير موجود',
      });
    }

    res.json({
      success: true,
      data: stock,
    });
  } catch (error) {
    logger.error(`خطأ في جلب السهم: ${error.message}`);
    next(error);
  }
};

