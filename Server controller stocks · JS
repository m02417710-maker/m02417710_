// ============================================================
// POST - عمليات التحليل
// ============================================================

/**
 * تحليل متقدم لسهم
 */
exports.analyzeStock = async (req, res, next) => {
  try {
    const { id } = req.params;

    logger.info(`جاري تحليل السهم ${id}`);

    const analysis = await stockService.analyzeStock(id);

    // بث النتائج عبر WebSocket
    const io = req.app.locals.io;
    if (io) {
      io.to(`stock-${analysis.code}`).emit('analysis-complete', analysis);
    }

    res.json({
      success: true,
      data: analysis,
    });
  } catch (error) {
    logger.error(`خطأ في تحليل السهم: ${error.message}`);
    next(error);
  }
};

/**
 * مقارنة عدة أسهم
 */
exports.compareStocks = async (req, res, next) => {
  try {
    const { stockIds } = req.body;

    if (!Array.isArray(stockIds) || stockIds.length === 0) {
      return res.status(400).json({
        success: false,
        message: 'يجب تحديد قائمة الأسهم',
      });
    }

    logger.info(`جاري مقارنة الأسهم: ${stockIds.join(', ')}`);

    const comparison = await stockService.compareStocks(stockIds);

    res.json({
      success: true,
      data: comparison,
    });
  } catch (error) {
    logger.error(`خطأ في مقارنة الأسهم: ${error.message}`);
    next(error);
  }
};

// ============================================================
// POST/PUT/DELETE - العمليات الإدارية
// ============================================================

/**
 * إنشاء سهم جديد
 */
exports.createStock = async (req, res, next) => {
  try {
    const { code, name, sector, subSector } = req.body;

    if (!code || !name) {
      return res.status(400).json({
        success: false,
        message: 'الكود والاسم مطلوبان',
      });
    }

    logger.info(`جاري إنشاء سهم جديد: ${code}`);

    const stock = await stockService.createStock({
      code,
      name,
      sector,
      subSector,
    });

    res.status(201).json({
      success: true,
      message: 'تم إنشاء السهم بنجاح',
      data: stock,
    });
  } catch (error) {
    logger.error(`خطأ في إنشاء السهم: ${error.message}`);
    next(error);
  }
};

/**
 * تحديث بيانات السهم
 */
exports.updateStock = async (req, res, next) => {
  try {
    const { id } = req.params;
