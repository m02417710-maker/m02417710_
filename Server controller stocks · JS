    const stock = await stockService.updateStock(id, updates);

    res.json({
      success: true,
      message: 'تم تحديث السهم بنجاح',
      data: stock,
    });
  } catch (error) {
    logger.error(`خطأ في تحديث السهم: ${error.message}`);
    next(error);
  }
};

