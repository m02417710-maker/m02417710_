/**
 * تحديث بيانات السهم من المصدر الخارجي
 */
exports.refreshStockData = async (req, res, next) => {
  try {
    const { id } = req.params;

    logger.info(`جاري تحديث بيانات السهم ${id}`);

    const stock = await stockService.refreshStockData(id);

    // بث التحديث عبر WebSocket
    const io = req.app.locals.io;
    if (io) {
      io.emit('stock-updated', stock);
    }

    res.json({
      success: true,
      message: 'تم تحديث البيانات بنجاح',
      data: stock,
    });
  } catch (error) {
    logger.error(`خطأ في تحديث البيانات: ${error.message}`);
    next(error);
  }
};

module.exports = exports;
