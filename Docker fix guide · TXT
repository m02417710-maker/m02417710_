الملف: entrypoint.sh (مُصحح)
─────────────────────────────

#!/bin/bash

set -e

# معالجة الأخطاء
handle_error() {
    echo "❌ خطأ: $1"
    exit 1
}

# التحقق من المسارات المطلوبة
check_paths() {
    local paths=("$@")
    for path in "${paths[@]}"; do
        if [ ! -e "$path" ]; then
            echo "⚠️  تحذير: المسار غير موجود: $path"
            # إنشاء المجلد إذا كان مجلداً
            if [[ "$path" == */ ]]; then
                mkdir -p "$path"
                echo "✓ تم إنشاء المجلد: $path"
            fi
        fi
    done
}

# تحميل الإعدادات
load_config() {
    local config_file="${1:-/mount/admin/install_path}"
    
    if [ -f "$config_file" ]; then
        echo "✓ تحميل الإعدادات من: $config_file"
        source "$config_file"
    else
        echo "⚠️  لم يتم العثور على ملف الإعدادات: $config_file"
        echo "📝 سيتم استخدام الإعدادات الافتراضية"
        
        # استخدم المتغيرات البيئية أو القيم الافتراضية
        export APP_PORT=${APP_PORT:-8000}
        export APP_HOST=${APP_HOST:-0.0.0.0}
        export DATABASE_URL=${DATABASE_URL:-""}
    fi
}

# التحقق من المسارات المطلوبة
check_paths "/mount/admin/" "/app/data/"

# تحميل الإعدادات
load_config

# عرض معلومات البدء
echo "════════════════════════════════════════════════"
echo "🚀 بدء التطبيق"
echo "════════════════════════════════════════════════"
echo "🔧 البيئة: ${APP_ENV:-development}"
echo "🌐 الخادم: ${APP_HOST}:${APP_PORT}"
echo "════════════════════════════════════════════════"

# بدء التطبيق
exec "$@"


الملف: docker-compose.yml (مُصحح)
──────────────────────────────────

version: '3.8'

services:
  # ✅ الخادم الخلفي
  backend:
    build:
      context: ./server
      dockerfile: Dockerfile
    container_name: stock-analyzer-backend
    ports:
      - "5000:5000"
    volumes:
      # استخدم مسارات نسبية
      - ./server:/app/server
      - ./config:/app/config
      - ./data:/app/data
    environment:
      - NODE_ENV=development
      - PORT=5000
      - DATABASE_URL=postgresql://user:pass@db:5432/stock_analyzer
      - REDIS_URL=redis://redis:6379
      - INSTALL_PATH=/app/config
    depends_on:
      - db
      - redis
    networks:
      - app-network
    restart: unless-stopped

  # ✅ العميل الأمامي
  frontend:
    build:
      context: ./client
      dockerfile: Dockerfile
    container_name: stock-analyzer-frontend
    ports:
      - "3000:3000"
    volumes:
      - ./client:/app
      - /app/node_modules
    environment:
      - REACT_APP_API_URL=http://backend:5000/api
    depends_on:
      - backend
    networks:
      - app-network
    restart: unless-stopped

  # ✅ قاعدة البيانات
  db:
    image: postgres:15-alpine
    container_name: stock-analyzer-db
    environment:
      - POSTGRES_USER=stock_user
      - POSTGRES_PASSWORD=secure_password
      - POSTGRES_DB=stock_analyzer
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./database/schema.sql:/docker-entrypoint-initdb.d/schema.sql
    networks:
      - app-network
    restart: unless-stopped

  # ✅ Redis
  redis:
    image: redis:7-alpine
    container_name: stock-analyzer-redis
    volumes:
      - redis_data:/data
    networks:
      - app-network
    restart: unless-stopped

volumes:
  postgres_data:
  redis_data:

networks:
  app-network:
    driver: bridge


الملف: Dockerfile (مُصحح للخادم)
───────────────────────────────────

FROM node:18-alpine

WORKDIR /app

# نسخ ملفات المشروع
COPY package*.json ./
COPY . .

# تثبيت المكتبات
RUN npm ci --only=production

# إنشاء المجلدات المطلوبة
RUN mkdir -p /app/config /app/data /mount/admin

# نسخ ملف البدء
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# منافذ التطبيق
EXPOSE 5000

# بدء التطبيق
ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "index.js"]


