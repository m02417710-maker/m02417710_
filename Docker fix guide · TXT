🐳 الحل 1: Docker Compose
───────────────────────────

المشكلة في docker-compose.yml:

❌ الكود الخاطئ:
version: '3'
services:
  app:
    build: .
    volumes:
      - /mount/admin:/app/mount  # خطأ! هذا المسار غير موجود

✅ الكود الصحيح:
version: '3'
services:
  app:
    build: .
    volumes:
      # استخدم مسار نسبي أو فعلي
      - ./config:/app/config
      - ./data:/app/data
      # أو
      - ${HOME}/admin:/app/admin
    environment:
      - APP_CONFIG_PATH=/app/config
      - INSTALL_PATH=/app/data/install_path

# الملف: Dockerfile
FROM node:18-alpine

WORKDIR /app

COPY . .

RUN npm install

# أنشئ المجلدات المطلوبة
RUN mkdir -p /app/config /app/data

# أصلح الـ entrypoint
COPY entrypoint.sh /
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]


🔷 الحل 2: Kubernetes
