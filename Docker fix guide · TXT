metadata:
  name: app-deployment
spec:
  template:
    spec:
      containers:
      - name: app
        image: app:latest
        volumeMounts:
        - name: admin-config
          mountPath: /mount/admin
      volumes:
      - name: admin-config
        configMap:
          name: admin-config
        # أو استخدم persistentVolumeClaim
